{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tl://schemas/wiremsg.v1.json",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "clientId", "want"],
      "properties": {
        "t": { "const": "HELLO" },
        "v": { "const": 1 },
        "clientId": { "type": "string" },
        "want": { "type": "array", "items": { "enum": ["TAPE", "SUBMIT", "RPC"] } }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "order"],
      "properties": {
        "t": { "const": "SUBMIT" },
        "v": { "const": 1 },
        "order": { "$ref": "tl://schemas/order-envelope.v1.json" }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v"],
      "properties": {
        "t": { "const": "TAPE_SUB" },
        "v": { "const": 1 },
        "fromSeq": { "type": "number" }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "entry"],
      "properties": {
        "t": { "const": "TAPE_ENTRY" },
        "v": { "const": 1 },
        "entry": { "$ref": "tl://schemas/tape-entry.v1.json" }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "lastSeq"],
      "properties": {
        "t": { "const": "TAPE_END" },
        "v": { "const": 1 },
        "lastSeq": { "type": "number" }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "nodeId", "services"],
      "properties": {
        "t": { "const": "RPC_ADVERTISE" },
        "v": { "const": 1 },
        "nodeId": { "type": "string" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["service"],
            "properties": {
              "service": { "type": "string" },
              "network": { "type": "string" },
              "methods": { "type": "array", "items": { "type": "string" } },
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "req"],
      "properties": {
        "t": { "const": "RPC_REQ" },
        "v": { "const": 1 },
        "req": {
          "type": "object",
          "additionalProperties": true,
          "required": ["id", "service", "method"],
          "properties": {
            "id": { "type": "string" },
            "service": { "type": "string" },
            "network": { "type": "string" },
            "method": { "type": "string" },
            "params": {},
            "timeoutMs": { "type": "number" }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "res"],
      "properties": {
        "t": { "const": "RPC_RES" },
        "v": { "const": 1 },
        "res": {
          "type": "object",
          "additionalProperties": true,
          "required": ["id", "ok"],
          "properties": {
            "id": { "type": "string" },
            "ok": { "type": "boolean" },
            "result": {},
            "error": {
              "type": "object",
              "additionalProperties": true,
              "required": ["message"],
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "data": {}
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "ts"],
      "properties": {
        "t": { "enum": ["PING", "PONG"] },
        "v": { "const": 1 },
        "ts": { "type": "number" }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["t", "v", "code", "msg"],
      "properties": {
        "t": { "const": "ERR" },
        "v": { "const": 1 },
        "code": { "type": "string" },
        "msg": { "type": "string" }
      }
    }
  ]
}
